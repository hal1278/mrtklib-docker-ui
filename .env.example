# MRTKLIB Web UI — Environment Variables

# MRTKLIB version (used as Docker build arg)
# MRTKLIB_VERSION=0.6.2

# Directory for output files and presets (read-write)
WORKSPACE_DIR=./workspace

# Directory for input GNSS data files (read-only)
# Set this to your local GNSS data directory, e.g.:
# DATA_DIR=/home/user/gnss-data
DATA_DIR=./data

# NASA Earthdata credentials (for IGS product downloads)
# Register at: https://urs.earthdata.nasa.gov/
# EARTHDATA_USER=
# EARTHDATA_PASSWORD=

# GSI CORS FTP credentials (for Japanese CORS data)
# Register at: https://terras.gsi.go.jp/
# GSI_USER=
# GSI_PASSWORD=

# Alternative: mount your existing ~/.netrc file
# NETRC_FILE=~/.netrc
